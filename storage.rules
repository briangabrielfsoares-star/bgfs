rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSetupAdmin() {
      return request.auth != null && request.auth.token.email == "briangabrielfsoares@gmail.com";
    }

    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if isSetupAdmin();
    }
  }
}
